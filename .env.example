# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# GROQ_API_KEY: Required for Groq AI API calls.
# Users configure this via the Secrets panel in the AI Studio UI.
GROQ_API_KEY="MY_GROQ_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# MONGODB_URI: Connection string for MongoDB Atlas.
MONGODB_URI="mongodb+srv://<username>:<password>@cluster.mongodb.net/vibe_pulse?retryWrites=true&w=majority"

# GOOGLE_CLIENT_ID: Required for Google Sign-In.
GOOGLE_CLIENT_ID="YOUR_GOOGLE_CLIENT_ID"
VITE_GOOGLE_CLIENT_ID="YOUR_GOOGLE_CLIENT_ID"

# JWT_SECRET: Required for JWT token signing.
JWT_SECRET="YOUR_JWT_SECRET"

# LinkedIn OAuth Credentials
LINKEDIN_CLIENT_ID="YOUR_LINKEDIN_CLIENT_ID"
LINKEDIN_CLIENT_SECRET="YOUR_LINKEDIN_CLIENT_SECRET"

# X (Twitter) OAuth Credentials
X_CLIENT_ID="YOUR_X_CLIENT_ID"
X_CLIENT_SECRET="YOUR_X_CLIENT_SECRET"

# Facebook OAuth Credentials
FACEBOOK_APP_ID="YOUR_FACEBOOK_APP_ID"
FACEBOOK_APP_SECRET="YOUR_FACEBOOK_APP_SECRET"
